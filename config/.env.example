# API CREDENTIALS - MUST BE CREATED MANUALLY VIA POLYMARKET UI
# ============================================================
# 1. Go to polymarket.com and connect your wallet
# 2. Go to Settings → API Keys
# 3. Click "Create API Key"
# 4. Copy the three values below:
POLY_API_KEY=your_polymarket_api_key
POLY_API_SECRET=your_polymarket_api_secret
POLY_API_PASSPHRASE=your_polymarket_api_passphrase
POLY_CRED_SIG_TYPE=1
